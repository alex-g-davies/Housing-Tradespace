# Copy to .env and fill in. .env is gitignored and read ONLY on the backend.

# Mapbox Isochrone API token. Leave blank to serve the committed isochrone
# fixture instead of calling Mapbox (fixture-first mode). When set, /api/isochrone
# fetches a live 30-min driving contour. NEVER expose this in the frontend.
MAPBOX_TOKEN=

# Default work location the commute isochrone originates from (Museum of Flight,
# Seattle). The frontend lets users move the point interactively; this is the
# server-side fallback when the client sends no lat/lon.
WORK_LAT=47.5180
WORK_LON=-122.2966

# Drive-time contour in minutes.
CONTOUR_MINUTES=30

# Force serving the committed fixture even if MAPBOX_TOKEN is set (useful for
# offline dev / tests). Defaults to false; auto-true when no token is present.
USE_FIXTURE=false

# --- Hardening (spec 004) ---

# Hard daily cap on upstream Mapbox calls (isochrone scenarios + geocodes).
# Cache hits spend nothing. 0 disables the breaker.
MAPBOX_DAILY_CALL_BUDGET=2000

# Per-IP rate limits (slowapi syntax). NOTE: these are read from the PROCESS
# environment at startup (os.getenv), NOT from this .env file — set them when
# launching, e.g. in PowerShell:
#   $env:RATE_LIMIT_UPSTREAM = "20/minute"; uvicorn app.main:app --reload
# 20/minute matches production (render.yaml): dual-workplace interactions
# burst up to ~6 requests (2 isochrones + commutes + reverse geocodes).
# RATE_LIMIT_UPSTREAM=10/minute (default)
# RATE_LIMIT_DATA=60/minute (default)

# CORS origins as a JSON list. Only matters for split-origin dev; in production
# the SPA is served same-origin by the backend (spec 006).
# CORS_ORIGINS=["http://localhost:5173"]

# "text" (default) or "json" — single-line JSON logs for cloud ingestion.
LOG_FORMAT=text

# --- Data build only (spec 008; not read by the app) ---

# Free Census API key for scripts/build_data.py ACS enrichment (population /
# median income). Sign up: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=
